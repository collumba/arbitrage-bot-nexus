# ═══════════════════════════════════════════════════════════
# ARBITRAGE NEXUS v4 — ENVIRONMENT CONFIGURATION
# ═══════════════════════════════════════════════════════════

# Modo: "paper" (simulacao) ou "live" (dinheiro real)
# Em "live", o bot usa ccxt create_order para enviar ordens REAIS
TRADING_MODE=paper

# Saldo inicial para paper trading (USD)
INITIAL_BALANCE=10

# ─── LIVE MODE SAFETY ─────────────────────────────────────
# Limite de perda diaria (USD) — bot para automaticamente ao atingir
LIVE_MAX_DAILY_LOSS=50
# Tamanho maximo de uma unica ordem (USD)
LIVE_MAX_ORDER=100

# ─── BINANCE ──────────────────────────────────────────────
BINANCE_API_KEY=
BINANCE_SECRET=

# ─── BYBIT ────────────────────────────────────────────────
BYBIT_API_KEY=
BYBIT_SECRET=

# ─── OKX ──────────────────────────────────────────────────
OKX_API_KEY=
OKX_SECRET=
OKX_PASSWORD=

# ─── KUCOIN ───────────────────────────────────────────────
KUCOIN_API_KEY=
KUCOIN_SECRET=
KUCOIN_PASSWORD=
